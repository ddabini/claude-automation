# ============================================
# VELA 백엔드 서버 환경변수 설정 파일
# 이 파일을 .env로 복사한 뒤 값을 채워주세요
# cp .env.example .env
# ============================================

# 서버 포트
PORT=3001

# Mock 모드 (true면 AI API 없이 테스트, false면 실제 Replicate API 사용)
# 실제 영상 생성을 하려면 false로 바꾸고 REPLICATE_API_TOKEN을 설정하세요
MOCK_MODE=true

# ── Replicate API (권장 — 가장 쉬운 방법) ──
# 1. https://replicate.com 가입
# 2. https://replicate.com/account/api-tokens 에서 토큰 발급
# 3. 아래에 붙여넣기
REPLICATE_API_TOKEN=your_token_here
# 모델 이름 (기본값 사용 시 생략 가능)
# REPLICATE_T2V_MODEL=wavespeedai/wan-2.1-t2v-480p
# REPLICATE_I2V_MODEL=wavespeedai/wan-2.1-i2v-480p

# ── RunPod Serverless API (고급 — 직접 GPU 배포 시) ──
# RUNPOD_API_KEY=your_key_here
# RUNPOD_ENDPOINT_ID=your_endpoint_here

# Whisper 음성 인식 설정
# 모델 크기: tiny, base, small, medium, large
WHISPER_MODEL=base
# 기본 언어: ko(한국어), en(영어), ja(일본어)
WHISPER_LANGUAGE=ko

# 파일 자동 정리 (시간 단위, 기본 24시간)
FILE_CLEANUP_HOURS=24
